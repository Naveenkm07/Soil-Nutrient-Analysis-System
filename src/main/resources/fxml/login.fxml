<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox alignment="CENTER" spacing="20.0" styleClass="login-container"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.soilanalysis.controllers.LoginController">
    
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- Logo and Title -->
    <VBox alignment="CENTER" spacing="10">
        <ImageView fitHeight="100.0" fitWidth="100.0" preserveRatio="true">
            <Image url="/images/logo.png"/>
        </ImageView>
        <Text styleClass="app-title" text="Soil Nutrient Analysis System"/>
        <Text styleClass="app-subtitle" text="Login to continue"/>
    </VBox>

    <!-- Login Form -->
    <VBox spacing="15" maxWidth="400" styleClass="login-form">
        <TextField fx:id="usernameField" promptText="Username" styleClass="login-field"/>
        <PasswordField fx:id="passwordField" promptText="Password" styleClass="login-field"/>
        
        <HBox alignment="CENTER_LEFT" spacing="10">
            <CheckBox fx:id="rememberMeCheckbox" text="Remember me"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Hyperlink fx:id="forgotPasswordLink" text="Forgot Password?" onAction="#handleForgotPassword"/>
        </HBox>

        <Button fx:id="loginButton" text="Login" onAction="#handleLogin" 
                styleClass="login-button" maxWidth="Infinity"/>
        
        <HBox alignment="CENTER" spacing="5">
            <Text text="Don't have an account?"/>
            <Hyperlink fx:id="registerLink" text="Register" onAction="#handleRegister"/>
        </HBox>
    </VBox>

    <!-- Language and Theme Selector -->
    <HBox alignment="CENTER" spacing="20">
        <ComboBox fx:id="languageComboBox" prefWidth="120" promptText="Language"/>
        <ComboBox fx:id="themeComboBox" prefWidth="120" promptText="Theme"/>
    </HBox>

    <!-- Status Message -->
    <Text fx:id="statusMessage" styleClass="status-message" visible="false"/>

    <!-- Footer -->
    <VBox alignment="CENTER" spacing="5">
        <Text styleClass="footer-text" text="© 2024 Soil Nutrient Analysis System"/>
        <Text styleClass="footer-text" text="Version 1.0.0"/>
    </VBox>
</VBox> 